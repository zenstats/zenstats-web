# ZenStats Caddy 配置（统一网关 + 静态文件服务）
# SPA（/）→ /srv 静态文件（Caddy 直接 serve，已移除 nginx）
# API（/api/）→ zenstats:8080（保留 /api 前缀，Go 后端路由注册在 /api 分组下）
# Tracker JS（/js/）→ /srv/js 静态文件 + CORS
#
# 本地开发：使用自签名证书
# 生产部署：自动申请 Let's Encrypt SSL

{$ZENSTATS_DOMAIN:localhost} {
	root * /srv

	# Tracker JS - 允许跨域访问，用于三方网站引用
	@trackerJs path /js/*
	handle @trackerJs {
		@jsOptions method OPTIONS
		header @jsOptions Access-Control-Allow-Origin "*"
		header @jsOptions Access-Control-Allow-Methods "GET, OPTIONS"
		header @jsOptions Access-Control-Allow-Headers "*"
		header @jsOptions Access-Control-Allow-Private-Network "true"
		header @jsOptions Access-Control-Max-Age "86400"
		respond @jsOptions 204
		header {
			Access-Control-Allow-Origin "*"
			Access-Control-Allow-Methods "GET, OPTIONS"
			Cross-Origin-Resource-Policy "cross-origin"
		}
		file_server {
			root /srv
		}
	}

	# Tracker event ingestion - 允许三方网站跨域上报
	handle /api/event {
		@eventOptions method OPTIONS
		header @eventOptions Access-Control-Allow-Origin "*"
		header @eventOptions Access-Control-Allow-Methods "POST, OPTIONS"
		header @eventOptions Access-Control-Allow-Headers "Content-Type, X-Requested-With"
		header @eventOptions Access-Control-Allow-Private-Network "true"
		header @eventOptions Access-Control-Max-Age "86400"
		respond @eventOptions 204
		reverse_proxy zenstats:8080 {
			# Gin backend already emits CORS headers. Avoid duplicated values.
		}
	}

	# API 请求代理到后端（包括事件上报端点 /api/event）
	# 注意：必须使用 handle 而非 handle_path
	# Go 后端路由注册为 /api/* 组（参见 cmd/server.go: api := r.Group("/api")）
	# handle_path 会剥离 /api 前缀，导致后端收到 /sites 而非 /api/sites，从而 404
	handle /api/* {
		reverse_proxy zenstats:8080
	}

	handle {
		try_files {path} /index.html
		file_server {
			root /srv
		}
	}

	# 安全头
	@notLocalhost not host localhost
	header @notLocalhost {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# 静态资源缓存
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# 请求日志
	log {
		output stdout
		format json
	}

	# 压缩
	encode gzip


}